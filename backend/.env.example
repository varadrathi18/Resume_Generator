# ── Gemini AI ────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_TOP_P=0.95
GEMINI_MAX_RETRIES=2

# ── ML Model Settings ───────────────────────────────────
# Set to false on Render (transformer model is too large)
USE_TRANSFORMER_MODEL=false

# ── Email (SMTP) — Gmail App Password recommended ───────
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=ResumeAI

# ── Server ──────────────────────────────────────────────
PORT=8080
FLASK_DEBUG=false
ALLOWED_ORIGINS=https://your-frontend.vercel.app
LOG_LEVEL=INFO
LOG_REQUESTS=true
CLEANUP_MAX_AGE_HOURS=24

# ── Database ────────────────────────────────────────────
MONGODB_URI=your_mongodb_uri_here
MONGODB_DB_NAME=Resume_Generator

# ── Authentication ──────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
JWT_SECRET_KEY=generate_a_secure_random_string_here
